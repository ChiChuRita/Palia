    "@livekit/agents-plugin-openai": "^1.4.5",
    "@livekit/react-native": "^2.10.3",
    "@livekit/react-native-expo-plugin": "^1.0.2",
    "@livekit/react-native-webrtc": "^144.0.0",
    "@react-native-async-storage/async-storage": "^3.1.0",
    "convex": "^1.39.1",
    "dotenv": "^17.4.2",
    "expo": "~56.0.4",
    "expo-constants": "~56.0.15",
    "expo-dev-client": "^56.0.15",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.9",
    "expo-linking": "~56.0.11",
    "expo-localization": "~56.0.6",
    "expo-router": "~56.2.6",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "i18n-js": "^4.5.3",
    "livekit-client": "^2.19.0",
    "livekit-server-sdk": "^2.15.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-health-connect": "^3.5.3",
    "react-native-nitro-modules": "^0.35.8",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/i18n-js": "^3.8.9",
    "@types/node": "^25.9.1",
    "@types/react": "~19.2.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "dev": "concurrently -n convex,agent,expo -c blue,magenta,green --kill-others-on-fail \"npm:dev:convex\" \"npm:dev:agent\" \"npm:dev:expo\"",
    "dev:convex": "convex dev",
    "dev:agent": "npm --prefix agent run dev",
    "dev:expo": "expo start",
    "ios": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 expo run:ios",
    "ios:rebuild": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 expo prebuild --platform ios --clean && LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "deploy:agent": "cd agent && lk agent deploy",
    "reset-project": "node ./scripts/reset-project.js"
  },
  "private": true
}
