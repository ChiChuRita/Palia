# LiveKit — for local dev only; in production LiveKit Cloud auto-injects these
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# OpenAI
OPENAI_API_KEY=

# Convex HTTP endpoint base (e.g. https://tidy-blackbird-755.convex.site)
CONVEX_HTTP_URL=

# Must match Convex env var AGENT_SHARED_SECRET
AGENT_SHARED_SECRET=
